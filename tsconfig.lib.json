{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": false,
        "allowImportingTsExtensions": false,
        "declaration": true,
        "declarationDir": "dist/lib",
        "emitDeclarationOnly": true,
        "rootDir": "src"
    },
    "include": [
        "src/index.ts",
        "src/island/index.ts",
        "src/cli.ts"
    ],
    "exclude": [
        "src/__tests__",
        "example"
    ]
}