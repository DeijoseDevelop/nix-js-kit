{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@deijose/nix-js-kit": [
        "./src/index.ts"
      ],
      "@deijose/nix-js-kit/island": [
        "./src/island/index.ts"
      ],
      "@deijose/nix-js-kit/cli": [
        "./src/cli.ts"
      ],
      "@deijose/nix-js-kit/vite": [
        "./src/vite/index.ts"
      ]
    },
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src",
    "example"
  ]
}