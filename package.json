{
  "name": "@deijose/nix-js-kit",
  "version": "0.2.0",
  "description": "Full-stack meta-framework for Nix.js — file-based routing, SSG and islands.",
  "license": "MIT",
  "author": "Deiver Vasquez",
  "homepage": "https://github.com/DeijoseDevelop/nix-js-kit",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DeijoseDevelop/nix-js-kit.git"
  },
  "type": "module",
  "keywords": [
    "nix-js",
    "meta-framework",
    "ssg",
    "islands",
    "file-based-routing",
    "ssr",
    "typescript"
  ],
  "main": "./dist/lib/nix-js-kit.cjs",
  "module": "./dist/lib/nix-js-kit.js",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/nix-js-kit.js",
      "require": "./dist/lib/nix-js-kit.cjs"
    }
  },
  "files": [
    "dist/lib",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "poc": "bun run example/build.ts",
    "build:example": "bun run example/build.ts",
    "typecheck": "tsc --noEmit",
    "build": "npm run build:lib",
    "build:lib": "vite build --config vite.lib.config.ts && tsc --project tsconfig.lib.json && terser dist/lib/nix-js-kit.js -c -m -o dist/lib/nix-js-kit.js && terser dist/lib/nix-js-kit.cjs -c -m -o dist/lib/nix-js-kit.cjs",
    "prepack": "npm run build:lib"
  },
  "dependencies": {
    "happy-dom": "^20.8.3"
  },
  "peerDependencies": {
    "@deijose/nix-js": "^2.5.3"
  },
  "devDependencies": {
    "@deijose/nix-js": "^2.6.0",
    "@types/node": "^22.10.0",
    "terser": "^5.46.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0"
  }
}